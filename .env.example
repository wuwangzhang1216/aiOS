# ═══════════════════════════════════════════════════
# Bash+DB AI-Native OS Experiment - Environment Config
# ═══════════════════════════════════════════════════
# Copy to .env and fill in values:  cp .env.example .env

# ── Database Root Passwords ──
GITEA_DB_PASS=gitea_secret
WIKI_DB_PASS=wiki_secret
MM_DB_PASS=mm_secret

# ── Agent Database Passwords (scoped users) ──
GITEA_AGENT_PASS=agent_gitea_pass
WIKI_AGENT_PASS=agent_wiki_pass
MM_AGENT_PASS=agent_mm_pass

# ── OpenRouter API ──
OPENROUTER_API_KEY=sk-or-xxx

# ── Experiment Settings ──
EXPERIMENT_RUNS_PER_VARIANT=5
EXPERIMENT_LOG_DIR=./results
