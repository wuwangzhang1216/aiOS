{
  "experiment": "bash-db-agent-os",
  "arm": "api",
  "apps": [
    {
      "id": "gitea",
      "name": "Gitea (Code & Git)",
      "base_url": "http://localhost:3000/api/v1",
      "auth_header": "Authorization: token ${GITEA_API_TOKEN}",
      "auth_env": "GITEA_API_TOKEN",
      "docs_url": "http://localhost:3000/api/swagger",
      "key_endpoints": [
        "GET /repos/search - Search repositories",
        "POST /user/repos - Create a repository",
        "GET /repos/{owner}/{repo} - Get a repository",
        "GET /repos/{owner}/{repo}/issues - List issues",
        "POST /repos/{owner}/{repo}/issues - Create an issue",
        "PATCH /repos/{owner}/{repo}/issues/{index} - Edit an issue",
        "GET /repos/{owner}/{repo}/labels - List labels",
        "POST /repos/{owner}/{repo}/issues/{index}/labels - Add labels to issue",
        "GET /users/{username} - Get a user"
      ]
    },
    {
      "id": "wikijs",
      "name": "Wiki.js (Knowledge Base)",
      "base_url": "http://localhost:3001/graphql",
      "auth_header": "Authorization: Bearer ${WIKIJS_API_TOKEN}",
      "auth_env": "WIKIJS_API_TOKEN",
      "type": "graphql",
      "key_queries": [
        "{ pages { list { id title path } } } - List all pages",
        "{ pages { single(id: INT) { id title content } } } - Get page by ID",
        "mutation { pages { create(content:STR, description:STR, editor:STR, isPublished:BOOL, isPrivate:BOOL, locale:STR, path:STR, title:STR) { responseResult { succeeded message } page { id } } } } - Create page",
        "mutation { pages { update(id:INT, content:STR, ...) { ... } } } - Update page",
        "{ pages { tags { id tag title } } } - List tags"
      ]
    },
    {
      "id": "mattermost",
      "name": "Mattermost (Team Chat)",
      "base_url": "http://localhost:3006/api/v4",
      "auth_header": "Authorization: Bearer ${MM_API_TOKEN}",
      "auth_env": "MM_API_TOKEN",
      "key_endpoints": [
        "GET /teams - List teams",
        "GET /teams/name/{name} - Get team by name",
        "GET /channels - List channels",
        "GET /teams/{team_id}/channels/name/{name} - Get channel by name",
        "POST /posts - Create a post",
        "GET /channels/{channel_id}/posts - Get posts in channel",
        "GET /users/username/{username} - Get user by username",
        "GET /users/{user_id} - Get user by ID"
      ]
    }
  ]
}
