{
  "serverRoot": "http://localhost:8000",
  "port": 8000,
  "dbtype": "postgres",
  "dbconfig": "postgres://postgres:secret@pg-focalboard:5432/focalboard?sslmode=disable",
  "useSSL": false,
  "webpath": "./pack",
  "filespath": "./files",
  "telemetry": false,
  "logging_cfg_file": "",
  "session_expire_time": 2592000,
  "session_refresh_time": 18000,
  "localOnly": false,
  "enableLocalMode": true,
  "localModeSocketLocation": "/var/tmp/focalboard_local.socket"
}
