{
  "description": "MCP server config for 4 experiment apps",
  "servers": {
    "gitea": {
      "command": "node",
      "args": ["node_modules/@boringstudio_org/gitea-mcp/index.js"],
      "env": {}
    },
    "miniflux": {
      "command": "node",
      "args": ["node_modules/miniflux-mcp/dist/server.js"],
      "env": {
        "MINIFLUX_URL": "http://localhost:3001",
        "MINIFLUX_API_KEY": "${MINIFLUX_API_TOKEN}"
      }
    },
    "vikunja": {
      "command": "node",
      "args": ["node_modules/@0xk3vin/vikunja-mcp/dist/index.js"],
      "env": {
        "VIKUNJA_URL": "http://localhost:3002/api/v1",
        "VIKUNJA_TOKEN": "${VIKUNJA_API_TOKEN}"
      }
    },
    "mattermost": {
      "command": "node",
      "args": ["node_modules/@dakatan/mcp-mattermost/build/index.js"],
      "env": {
        "MCP_MATTERMOST_URL": "http://localhost:3003",
        "MCP_MATTERMOST_TOKEN": "${MM_API_TOKEN}",
        "MCP_MATTERMOST_TEAM_NAME": "experiment"
      }
    }
  }
}
